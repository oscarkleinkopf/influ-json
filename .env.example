# influ-JSON Studio — copy to .env and fill in

# Google Gemini (optional; without it the app runs offline / prompt-copy mode)
GEMINI_API_KEY=

# Studio PIN (leave empty to disable auth)
STUDIO_PIN=1234

# Optional: absolute path for SQLite + mirrors (default: ./data next to package.json)
# DATA_DIR=C:\path\to\your\data

# Optional: one-time migration source if you still have an old Antigravity scratch DB
# LEGACY_SCRATCH_DIR=C:\Users\you\.gemini\antigravity\brain\...\scratch
