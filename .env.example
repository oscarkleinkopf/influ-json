# influ-JSON Studio — copy to .env and fill in
#
# FREE-FIRST: the app works without any paid image API.
# Small entrepreneurs should not need a credit card for the basic loop.

# ─── Core (optional) ───────────────────────────────────────────
# Google Gemini (optional; without it → offline / prompt-copy + Pollinations)
GEMINI_API_KEY=

# Studio PIN (leave empty to disable auth)
STUDIO_PIN=1234

# ─── Data ──────────────────────────────────────────────────────
# Optional: absolute path for SQLite + mirrors (default: ./data)
# DATA_DIR=C:\path\to\your\data

# Optional: one-time migration source for old Antigravity scratch DB
# LEGACY_SCRATCH_DIR=C:\Users\you\.gemini\antigravity\brain\...\scratch

# ─── Image generation ──────────────────────────────────────────
# Default: pollinations (FREE, no key)
IMAGE_PROVIDER=pollinations

# Future optional paid face-lock (NOT required). When unimplemented or
# token missing, the app always falls back to Pollinations.
# IMAGE_PROVIDER=replicate
# REPLICATE_API_TOKEN=
# REPLICATE_FACE_MODEL=   # e.g. InstantID / PuLID model version when wired

# Future self-host (optional)
# IMAGE_PROVIDER=comfyui
# COMFYUI_URL=http://127.0.0.1:8188
